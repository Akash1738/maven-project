pipeline {
    agent any

    tools {
        maven 'Maven-3.9.6'   // Name from Global Tool Configuration
        jdk 'jdk17'           // If you configured JDK in Jenkins
    }

    stages {
        stage('Checkout') {
            steps {
                git 'https://github.com/your-repo/hello-world-maven.git'
            }
        }
        stage('Build') {
            steps {
                sh 'mvn clean install'
            }
        }
        stage('Test') {
            steps {
                sh 'mvn test'
            }
        }
        stage('Package') {
            steps {
                sh 'mvn package'
            }
        }
    }
}
